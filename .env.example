# ==========================================================================
# BE-COMIC — cấu hình local development
# ==========================================================================

# HTTP server (3000 — default 8000 đụng cổng health của image-ai)
PORT=3000

# CORS: các origin FE được phép gọi, cách nhau dấu phẩy.
# Deploy thêm domain thật: http://localhost:4200,https://comic.example.com
CORS_ORIGINS=http://localhost:4200

# Database Postgres (container be-comic-postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=your_password_here
DB_DATABASE=comic_db

# gRPC orchestrator-ai (50054 — KHÔNG phải 50052, đó là story-ai)
ORCHESTRATOR_URL=localhost:50054
